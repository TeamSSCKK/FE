# --------------------------------------------------------------------
# 모여(Moyeo) Frontend — 환경변수 템플릿
# 사용 시: cp .env.example .env.local 후 값 채우기
# 'NEXT_PUBLIC_' prefix가 붙은 값은 브라우저에 노출되니 비밀키 금지!
# --------------------------------------------------------------------

# Supabase 프로젝트 URL (Next.js rewrite 프록시 설정에 사용)
NEXT_PUBLIC_SUPABASE_URL=https://oufchidafmrxgympbcqo.supabase.co

# Supabase anon key (공개 가능 — Edge Function 인증용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (서버 전용 — 절대 NEXT_PUBLIC_ 사용 금지)
SUPABASE_SERVICE_ROLE_KEY=

# 네이버 지도 JavaScript API 클라이언트 ID
# https://console.ncloud.com → Application → Maps에서 발급
# Web Service URL에 http://localhost:3000 등록 필수
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# 네이버 지역 검색 Open API (장소/주소 검색)
# https://developers.naver.com/apps 에서 애플리케이션 등록 후 발급
# ⚠️ 서버 전용 — 절대 NEXT_PUBLIC_ prefix 사용 금지
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
