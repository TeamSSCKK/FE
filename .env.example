# --------------------------------------------------------------------
# 모여(Moyeo) Frontend — 환경변수 템플릿
# 사용 시: cp .env.example .env.local 후 값 채우기
# 'NEXT_PUBLIC_' prefix가 붙은 값은 브라우저에 노출되니 비밀키 금지!
# --------------------------------------------------------------------

# 백엔드 API base URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# 카카오맵 JavaScript SDK 키 (https://developers.kakao.com)
NEXT_PUBLIC_KAKAO_MAP_KEY=
